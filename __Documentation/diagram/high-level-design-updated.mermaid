graph LR
    %% --- ACTORS ---
    P((Patient))
    D((Doctor))
    S((Specialist))
    AD((Admin))

    %% --- CLIENTS ---
    subgraph Clients ["Client Applications"]
        APP["Web App"]
        AD_UI["Admin Dashboard"]
    end

    %% --- API LAYER ---
    subgraph Gateway ["API Gateway & Transport"]
        REST["REST API (Express.js)"]
        SOCKET["Socket.IO Server"]
    end

    %% --- CORE SERVICES ---
    subgraph Services ["Core Business Modules"]
        AUTH["Auth & User Service"]
        TRAIN["Training & Workout Service"]
        CLIN["Clinical & Protocol Service"]
        STORE["Store & Order Service"]
        APPT["Appointment & Scheduling Service"]
        WALLET["Wallet & Payment Service"]
        SUB["Subscription Service"]
        CHAT["Chatting & Communication Service"]
        DOCS["Client Documents & Attachments Service"]
        TRACK["Success Tracker Service"]
    end
    
    %% --- BACKGROUND WORKERS ---
    subgraph BackgroundJob ["Background Process"]
        WORKER["BullMQ Workers"]
    end

    %% --- DATA LAYER ---
    subgraph DataLayer ["Data & Storage"]
        DB[(MongoDB)]
        REDIS[(Redis Cache / PubSub)]
    end

    %% --- EXTERNAL INTEGRATIONS ---
    subgraph External ["External Services"]
        STRIPE["Stripe API"]
        FCM["Firebase Cloud Messaging"]
        MAIL["Email Provider"]
    end

    %% --- CONNECTIONS ---
    P --> APP
    D --> APP
    S --> APP
    AD --> AD_UI

    APP & AD_UI -->|HTTPS| REST
    APP <-->|WebSocket| SOCKET

    REST --> AUTH & TRAIN & CLIN & STORE & APPT & WALLET & SUB & DOCS & TRACK
    SOCKET <--> CHAT
    
    %% Service to DB
    AUTH & TRAIN & CLIN & STORE & APPT & WALLET & SUB & DOCS & TRACK & CHAT -->|"Read/Write"| DB
    
    %% Redis Connections (Cache, Queue, PubSub)
    CHAT <-->|"Socket State/PubSub"| REDIS
    REST -.->|"Queue Jobs"| REDIS
    STORE <-->|"Cache Queries (Products)"| REDIS
    REDIS <-->|"Process Jobs"| WORKER
    
    %% Workers Processing Background Tasks
    WORKER -.->|Push Notifications| FCM
    WORKER -.->|Send Emails| MAIL
    WORKER -.->|Schedule Updates| DB

    %% External Payments
    WALLET & SUB <-->|"Payments, Subscriptions & Payouts"| STRIPE

    %% --- ANNOTATIONS ---
    subgraph Annotations ["Technical Notes & Architecture Logic"]
        direction TB
        N1["<b>Real-time Chat:</b><br/>Socket.IO uses Redis Adapter.<br/>Redis Pub/Sub synchronizes state across multiple workers."]
        N2["<b>Background Jobs (BullMQ):</b><br/>Handles schedules, notifications, and async data updates (e.g., LastMessage)."]
        N3["<b>Payment Processing:</b><br/>Uses Stripe Connected Accounts to automatically split platform fees and credit wallets."]
        N4["<b>Product Caching (Redis):</b><br/>Frequent e-commerce queries (Categories, Page 1 Products, Product Details) are cached for speed."]
    end

    CHAT -.-> N1
    WORKER -.-> N2
    WALLET -.-> N3
    STORE -.-> N4