      "boundElements": [],
      "updated": 1768381431324,
      "link": null,
      "locked": false,
      "text": "1. find user by email\n2. validateUserStatus // check for isDeleted\n3. handle account logged case [rate limit]\n4. check password maching\n5. |-> for failed attempt lock account for some time\n6. if password matched ...\n7. return proper response based on role\n8. if everything is ok .. then return accessTokens",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "R4qbVZww76h3NRClOLYm4",
      "originalText": "1. find user by email\n2. validateUserStatus // check for isDeleted\n3. handle account logged case [rate limit]\n4. check password maching\n5. |-> for failed attempt lock account for some time\n6. if password matched ...\n7. return proper response based on role\n8. if everything is ok .. then return accessTokens",
      "autoResize": true,
      "lineHeight": 1.25
    },
