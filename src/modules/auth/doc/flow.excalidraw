      "updated": 1768730399527,
      "link": null,
      "locked": false,
      "text": "    verificationEmailToken(createdUser)\n    --------------------------------------------\n    1. prepare payload with userId, email, role\n    2. delete all previous token\n    3. create Token by payload, tokensecrect, \n       expirationTime\n    4.  calculate expirationTime of that token\n    5. create token in mongo db",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "DMqDbHEORKCVdf4i_ciLS",
      "originalText": "    verificationEmailToken(createdUser)\n    --------------------------------------------\n    1. prepare payload with userId, email, role\n    2. delete all previous token\n    3. create Token by payload, tokensecrect, \n       expirationTime\n    4.  calculate expirationTime of that token\n    5. create token in mongo db",
      "autoResize": true,
      "lineHeight": 1.25
    },
