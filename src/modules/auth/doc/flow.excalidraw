    {
      "id": "6ntkX575p_Ke_3gtCljh6",
      "type": "text",
      "x": -154.84284538221186,
      "y": 857.3654079237486,
      "width": 548.0196533203125,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1L",
      "roundness": null,
      "seed": 367166930,
      "version": 1600,
      "versionNonce": 184222530,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768730115088,
      "link": null,
      "locked": false,
      "text": "1. check for user object by email\n    |-> if user exist.. check for isEmailVerified\n    |-> if not verified .. send otp and verification token\n2. has the given password\n3. create the User\n4. use eventEmitter to add userProfileId to User Table\n[🎯Optimized]\n\n5. if not patient \n    |-> use eventEmitter to create wallet\n    |-> send notification to admin\n    |-> return user\n\n6.  if patient [🐛]\n    |->  create verificationEmailToken(createdUser)\n    |-> create otp and send mail by eventEmitter \n        [🎯Optimized]\n    |-> return user\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "inCzmBYI8HoqAivOfqnwB",
      "originalText": "1. check for user object by email\n    |-> if user exist.. check for isEmailVerified\n    |-> if not verified .. send otp and verification token\n2. has the given password\n3. create the User\n4. use eventEmitter to add userProfileId to User Table [🎯Optimized]\n\n5. if not patient \n    |-> use eventEmitter to create wallet\n    |-> send notification to admin\n    |-> return user\n\n6.  if patient [🐛]\n    |->  create verificationEmailToken(createdUser)\n    |-> create otp and send mail by eventEmitter \n        [🎯Optimized]\n    |-> return user\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
